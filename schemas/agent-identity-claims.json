{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.sigmashake.com/schemas/agent-identity-claims.json",
  "title": "AgentIdentityClaims",
  "description": "Claims returned when verifying an agent identity token",
  "type": "object",
  "required": ["agent_id", "capabilities", "trust_domain", "issued_at", "expires_at", "issuance_model", "delegation_chain"],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trust_domain": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "issuance_model": {
      "type": "string",
      "enum": ["direct", "delegated"]
    },
    "delegator": {
      "type": "string",
      "format": "uuid"
    },
    "delegation_chain": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    }
  },
  "additionalProperties": false
}
